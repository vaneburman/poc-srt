# === LLM ===
GEMINI_API_KEY=tu_api_key_aqui

# === Backend ===
# URL del endpoint Java de siniestros (entorno Dev)
JAVA_ENDPOINT_URL=http://localhost:8080/api/siniestros/srt

# true = usa archivos JSON locales en mock_data/
# false = llama al endpoint Java real
USE_MOCK_DATA=true

# === Paths ===
FAISS_INDEX_PATH=./rag/faiss_index
SCHEMAS_PATH=./schemas
MOCK_DATA_PATH=./mock_data

# === RAG ===
# Modelo de embeddings (cambiar si se necesita mejor calidad en español)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# === LLM Config ===
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
